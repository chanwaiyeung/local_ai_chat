# .env

# ==========================================
# 🧠 本地端 Flutter AI 伺服器設定
# ==========================================
LOCAL_API_URL=http://127.0.0.1:8080
AI_LIB_TOKEN=your_flutter_api_token_here
PORT=3001

# ==========================================
# 📱 Telegram Bot 設定
# ==========================================
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ==========================================
# 🟩 WhatsApp Cloud API 設定
# ==========================================
WHATSAPP_TOKEN=your_whatsapp_graph_api_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# ==========================================
# 💬 WeChat 公眾號設定
# ==========================================
WECHAT_TOKEN=your_custom_wechat_server_token
WECHAT_APP_ID=your_wechat_app_id
